# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (optional - for sending emails)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="FormaPro <noreply@formapro.fr>"

# Chiffrement applicatif des champs sensibles (NSS Contact)
# Générer avec : openssl rand -base64 32  (32 bytes = AES-256)
# Sans cette var, les routes qui lisent/écrivent un NSS lèveront une erreur.
# Voir prisma/migrate-nss-encryption.ts pour la migration initiale des données.
NSS_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Rate limiting — Upstash Redis (recommandé en prod Netlify)
# Sans ces vars, le rate-limit dégrade en in-memory inefficace (multi-instances Netlify).
# Créer un compte gratuit sur https://upstash.com → Redis → REST endpoint.
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# Observability — Sentry
# Sans ces vars, Sentry est désactivé silencieusement (no-op).
# Créer un projet sur https://sentry.io → Next.js → copier le DSN.
# `NEXT_PUBLIC_SENTRY_DSN` = côté client (browser). `SENTRY_DSN` = côté server/edge.
# Même valeur acceptée pour les deux.
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Source maps upload (optionnel — debug stack traces minifiées) :
# SENTRY_ORG="your-sentry-org-slug"
# SENTRY_PROJECT="your-sentry-project-slug"
# SENTRY_AUTH_TOKEN="sntrys_xxx"

# Signature électronique V1 — voir docs/superpowers/specs/2026-05-12-signature-electronique-self-hosted-design.md
SECRET_HMAC_TOKENS="generate-with-openssl-rand-base64-32"
# SECRET_HMAC_TOKENS_OLD=""                          # Pour rotation : conserve l'ancien secret pendant la migration
SIGNATURE_TOKEN_EXPIRY_DAYS=30
FREETSA_URL="https://freetsa.org/tsr"
FREETSA_CERT_URL="https://freetsa.org/files/tsa.crt"
SIGNATURE_MAX_FILE_SIZE_MB=25
SIGNATURE_MAX_PAGES=50
