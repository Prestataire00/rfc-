  dateIncident DateTime
  actionMenee  String?
  statut       String   @default("ouvert") // ouvert, traite, cloture

  @@index([statut])
  @@index([gravite])
  @@index([dateIncident])
}

// Token public pour partager le dashboard Qualiopi (lecture seule)
model PartageQualiopi {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  token            String    @unique
  nom              String    // libelle du share
  expireAt         DateTime?
  actif            Boolean   @default(true)
  createdByUserId  String?

  @@index([token])
  @@index([actif])
}

// ==================== EMAIL OBSERVABILITY ====================

// Historique des emails envoyes (pour audit + reconciliation Resend)
model LogEmail {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  destinataire String
  sujet        String
  templateId   String?
  template     MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  statut       String  @default("envoye") // envoye, livre, ouvert, clique, bounce, plainte
  messageId    String? // Resend ID
  erreur       String?
  sessionId    String?
  contactId    String?

  events EmailTrackingEvent[]

  @@index([destinataire])
  @@index([statut])
  @@index([templateId])
  @@index([createdAt])
}

// Evenements granulaires email (open / click / bounce / complaint)
model EmailTrackingEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  logEmailId String
  logEmail   LogEmail @relation(fields: [logEmailId], references: [id], onDelete: Cascade)

  type      String  // open, click, bounce, complaint, delivered
  payload   Json    @default("{}")
  userAgent String?
  ipAddress String?

  @@index([logEmailId])
  @@index([type])
}

// ==================== SMS ====================

// Templates SMS parametrables
model SmsTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  description String?
  contenu     String   // max 160 chars conventionally
  variables   String   @default("[]")
  actif       Boolean  @default(true)

  logs LogSms[]
}

// Historique SMS envoyes
model LogSms {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  destinataire String
  contenu      String
  statut       String  @default("envoye") // envoye, livre, echec
  templateId   String?
  template     SmsTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contactId    String?
  sessionId    String?
  providerId   String?
  erreur       String?

  @@index([destinataire])
  @@index([statut])
  @@index([templateId])
  @@index([createdAt])
}

// ==================== DOCUMENTS AVANCE ====================

// Categorisation des documents
model DocumentCategory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nom         String  @unique
  couleur     String  @default("#dc2626")
  description String?
}

// Signatures electroniques sur documents
model SignatureDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  documentId      String?
  userId          String?
  contactId       String?
  signatureBase64 String   // base64 PNG data URL
  dateSignature   DateTime @default(now())
  ipAddress       String?
  userAgent       String?
  valide          Boolean  @default(true)

  @@index([documentId])
  @@index([userId])
  @@index([contactId])
}

// Historique de PDFs generes (audit + retelechargement)
model GeneratedDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type              String  // convocation, convention, attestation, facture, devis, feuille_presence, ...
  templateUsed      String?
  template          DocumentTemplate? @relation(fields: [templateUsed], references: [id], onDelete: SetNull)
  sessionId         String?
  contactId         String?
  factureId         String?
  devisId           String?
  fichierUrl        String?
  generatedByUserId String?

  @@index([type])
  @@index([sessionId])
  @@index([contactId])
  @@index([factureId])
  @@index([devisId])
  @@index([createdAt])
}

// ==================== CHAMPS PERSONNALISES ====================

// Definition d'un champ personnalise applicable a une entite
model ChampPersonnalise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  label       String
  type        String  // text, number, date, select, boolean, textarea
  entiteCible String  // Contact, Entreprise, Formation, Session, Inscription
  options     Json?   // pour les selects : [{ value, label }]
  obligatoire Boolean @default(false)
  ordre       Int     @default(0)
  actif       Boolean @default(true)

  valeurs ValeurChampPersonnalise[]

  @@index([entiteCible])
  @@index([actif])
}

// Valeur stockee pour un champ personnalise sur une entite donnee
model ValeurChampPersonnalise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  champId  String
  champ    ChampPersonnalise @relation(fields: [champId], references: [id], onDelete: Cascade)

  entiteId String   // UUID de l'entite cible (Contact, Entreprise, ...)
  valeur   String

  @@index([champId, entiteId])
  @@index([entiteId])
}

// ==================== ADMIN / SYSTEME ====================

// Cles API pour integrations externes (n8n, Make, scripts...)
model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nom              String
  hashKey          String   @unique // hash SHA-256 de la cle
  prefix           String   // premiers chars de la cle pour affichage UI
  permissions      String   @default("[]") // JSON array de scopes
  lastUsedAt       DateTime?
  expireAt         DateTime?
  revokedAt        DateTime?
  createdByUserId  String?

  @@index([hashKey])
  @@index([revokedAt])
}

// Demandes RGPD (acces, rectification, effacement, portabilite, opposition)
model DemandeRgpd {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type             String   // acces, rectification, effacement, portabilite, opposition
  demandeurEmail   String
  demandeurNom     String?
  statut           String   @default("recue") // recue, en_traitement, traitee, rejetee
  description      String?
  traiteParUserId  String?
  dateTraitement   DateTime?
  justificatif     String?

  @@index([statut])
  @@index([demandeurEmail])
  @@index([type])
}

// Snapshots quotidiens d'indicateurs cles (pour graphes historiques)
model KpiHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  dateSnapshot DateTime  // precision jour
  kpis         Json      // { totalContacts, totalSessions, ... }
  source       String    @default("cron")

  @@index([dateSnapshot])
  @@index([source])
}
