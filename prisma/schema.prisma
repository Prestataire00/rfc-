generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== AUTHENTICATION ====================

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String @unique
  password String
  nom      String
  prenom   String
  role     String @default("admin") // admin, formateur, client
  actif    Boolean @default(true)

  formateurId  String?  @unique
  formateur    Formateur? @relation(fields: [formateurId], references: [id])

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id])

  notifications Notification[]
}

// ==================== CORE MODELS ====================

model Entreprise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom        String
  secteur    String?
  adresse    String?
  ville      String?
  codePostal String?
  siret      String?  @unique
  email      String?
  telephone  String?
  site       String?
  notes      String?

  // Champs complementaires (Qualiopi / BPF)
  effectif       Int?
  typeEntreprise String?  // TPE, PME, ETI, GE

  contacts      Contact[]
  devis         Devis[]
  factures      Facture[]
  users         User[]
  documents     Document[]
  besoins       BesoinFormation[]
  besoinsClient BesoinClient[]
  financements  Financement[]
  historique    HistoriqueAction[]
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom       String
  prenom    String
  email     String  @unique
  telephone String?
  poste     String?
  notes     String?
  type      String  @default("prospect") // prospect, client, stagiaire

  // Donnees stagiaire (Qualiopi / BPF / Passeport Prevention)
  dateNaissance              DateTime?
  numeroSecuriteSociale      String?  // stockage en clair pour l'instant, chiffrement applicatif a prevoir
  numeroPasseportPrevention  String?  // decret 2022-1434
  besoinsAdaptation          String?  // RQTH / contraintes
  niveauFormation            String?  // sans_diplome | cap | bac | bac+2 | autre

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  inscriptions     Inscription[]
  devis            Devis[]
  attestations     Attestation[]
  evaluations      Evaluation[]
  besoins          BesoinFormation[]
  besoinsStagiaire BesoinStagiaire[]
  feuillesPresence FeuillePresence[]
  historique       HistoriqueAction[]
}

model Formateur {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom             String
  prenom          String
  email           String  @unique
  telephone       String?
  specialites     String  @default("[]")
  tarifJournalier Float?
  cv              String?
  photo           String?  // URL photo de profil
  notes           String?
  actif           Boolean @default(true)

  sessions       Session[]
  disponibilites Disponibilite[]
  documents      Document[]
  feedbacks      FeedbackFormateur[]
  user           User?
}

model Formation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre       String
  description String?
  duree       Int      // en heures
  tarif       Float
  niveau      String   @default("tous")
  prerequis   String?
  objectifs   String?
  categorie   String?
  actif       Boolean  @default(true)
  certifiante Boolean  @default(false)
  codeRNCP    String?

  // Nouveaux champs inspirés SoSafe
  modalite           String   @default("presentiel") // presentiel, distanciel, mixte
  statut             String   @default("brouillon") // brouillon, publiee, archivee
  publicCible        String?  // public visé
  contenuProgramme   String?  // contenu détaillé du programme
  methodesPedagogiques String? // méthodes pédagogiques utilisées
  methodesEvaluation String?  // méthodes d'évaluation
  moyensTechniques   String?  // moyens techniques mis à disposition
  accessibilite      String?  // informations sur l'accessibilité PMR
  indicateursResultats String? // indicateurs de résultats
  typesFinancement   String   @default("[]") // JSON array: opco, cpf, entreprise, etc.
  dureeRecyclage     Int?     // durée de recyclage en mois (pour certifications)
  misEnAvant         Boolean  @default(false) // formation featured
  image              String?  // URL image de couverture

  sessions Session[]
  besoins  BesoinFormation[]
}

model LieuFormation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom              String
  adresse          String?
  codePostal       String?
  ville            String?
  pays             String   @default("France")
  salles           String   @default("[]") // JSON array de noms de salles
  capacite         Int?
  equipements      String?  // description des équipements
  tarifJournee     Float?
  tarifDemiJournee Float?
  contactNom       String?
  contactTelephone String?
  contactEmail     String?
  accessibilitePMR Boolean  @default(false)
  consignesAcces   String?  // comment y accéder
  infoParking      String?
  infoTransport    String?
  notes            String?
  actif            Boolean  @default(true)

  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dateDebut     DateTime
  dateFin       DateTime
  lieu          String?
  capaciteMax   Int     @default(10)
  statut        String  @default("planifiee") // planifiee, confirmee, en_cours, terminee, annulee
  tokenInscription String? @unique
  notes         String?
  coutFormateur Float?

  // Chemin express (< 48h) : desactive les automatisations temporelles
  modeExpress   Boolean @default(false)

  // Conformite Passeport Prevention (decret 2022-1434) pour formations certifiantes
  declarationPasseportPrevention Boolean   @default(false)
  datePasseportPrevention        DateTime?

  formationId String
  formation   Formation  @relation(fields: [formationId], references: [id], onDelete: Cascade)

  formateurId String?
  formateur   Formateur? @relation(fields: [formateurId], references: [id], onDelete: SetNull)

  lieuFormationId String?
  lieuFormation   LieuFormation? @relation(fields: [lieuFormationId], references: [id], onDelete: SetNull)

  devisId String?
  devis   Devis?  @relation(fields: [devisId], references: [id], onDelete: SetNull)

  inscriptions     Inscription[]
  feuillesPresence FeuillePresence[]
  attestations     Attestation[]
  evaluations      Evaluation[]
  feedbacks        FeedbackFormateur[]
  documents        Document[]
  besoinsClient    BesoinClient[]
  besoinsStagiaire BesoinStagiaire[]
  automations      SessionAutomation[]
}

model Inscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statut          String   @default("en_attente") // en_attente, confirmee, annulee, presente, absente
  dateInscription DateTime @default(now())
  notes           String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([contactId, sessionId])
}

// ==================== COMMERCIAL ====================

model BesoinFormation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre       String
  description String?
  origine     String  @default("client") // client, stagiaire, centre
  statut      String  @default("nouveau") // nouveau, qualifie, devis_envoye, accepte, refuse, archive
  priorite    String  @default("normale") // basse, normale, haute, urgente
  nbStagiaires Int?
  datesSouhaitees String?
  budget      Float?
  notes       String?

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  contactId    String?
  contact      Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  formationId  String?
  formation    Formation?  @relation(fields: [formationId], references: [id], onDelete: SetNull)

  devisId      String?
  devis        Devis?      @relation(fields: [devisId], references: [id], onDelete: SetNull)
}

model Devis {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numero       String   @unique
  objet        String
  montantHT    Float
  tauxTVA      Float    @default(20)
  montantTTC   Float
  dateEmission DateTime @default(now())
  dateValidite DateTime
  dateSigne    DateTime?
  signatureUrl String?
  notes        String?
  statut       String   @default("brouillon") // brouillon, envoye, signe, refuse, expire

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  lignes   LigneDevis[]
  factures Facture[]
  besoins  BesoinFormation[]
  sessions Session[]
}

model LigneDevis {
  id String @id @default(cuid())

  designation  String
  quantite     Int   @default(1)
  prixUnitaire Float
  montant      Float

  devisId String
  devis   Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model Facture {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numero       String   @unique
  montantHT    Float
  tauxTVA      Float    @default(20)
  montantTTC   Float
  dateEmission DateTime @default(now())
  dateEcheance DateTime
  datePaiement   DateTime?
  paiements      Json?     // [{mode: string, montant: number}]
  notes          String?
  statut         String   @default("en_attente") // en_attente, envoyee, payee, en_retard, annulee

  devisId String?
  devis   Devis?  @relation(fields: [devisId], references: [id], onDelete: SetNull)

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
}

// ==================== FORMATEUR ====================

model Disponibilite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  dateDebut DateTime
  dateFin   DateTime
  type      String   @default("disponible") // disponible, indisponible
  notes     String?

  formateurId String
  formateur   Formateur @relation(fields: [formateurId], references: [id], onDelete: Cascade)
}

model FeedbackFormateur {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  noteGlobale       Int     // 1-5
  commentaire       String?
  conditionsMat     String? // conditions matérielles
  dynamiqueGroupe   String?
  suggestions       String?

  formateurId String
  formateur   Formateur @relation(fields: [formateurId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([formateurId, sessionId])
}

// ==================== DOCUMENTS ====================

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nom        String
  type       String  // convention, feuille_presence, convocation, attestation, contrat, autre
  chemin     String  // file path or URL
  taille     Int?    // file size in bytes

  sessionId    String?
  session      Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  formateurId  String?
  formateur    Formateur?  @relation(fields: [formateurId], references: [id], onDelete: SetNull)

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
}

// ==================== EVALUATIONS & ATTESTATIONS ====================

model Evaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type         String  // satisfaction_chaud, satisfaction_froid, acquis
  cible        String  // stagiaire, client, formateur
  noteGlobale  Int?    // 1-5
  reponses     String  @default("{}") // JSON des réponses
  commentaire  String?
  estComplete  Boolean @default(false)
  tokenAcces   String? @unique // pour accès par lien unique

  // Snapshot des questions du template au moment de l'envoi (fige le contenu).
  // Si null, fallback sur le template associe (ou QuestionnaireConfig pour l'ancien systeme).
  questionsSnapshot String?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model EvaluationTemplate {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nom         String
  description String?
  type        String   @default("custom") // satisfaction_chaud, satisfaction_froid, acquis, custom
  questions   String   @default("[]") // JSON array of question objects
  preset      Boolean  @default(false) // true = preset officiel non modifiable
  icon        String?  // icone lucide ou emoji
  ordre       Int      @default(0) // ordre d'affichage dans le catalogue
}

model Attestation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type         String  @default("fin_formation") // fin_formation, presence, competences
  statut       String  @default("generee") // generee, validee, envoyee
  chemin       String? // file path
  dateValidation DateTime?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sessionId, contactId, type])
}

model FeuillePresence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  date      DateTime
  matin     Boolean @default(false)
  apresMidi Boolean @default(false)
  signature String? // could be a signature data URL

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sessionId, contactId, date])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  titre     String
  message   String
  type      String   @default("info") // info, warning, success, error
  lu        Boolean  @default(false)
  lien      String?  // optional link to navigate to

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== BPF ====================

model Financement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type       String  // opco, entreprise, personnel, pole_emploi, cpf, autre
  organisme  String?
  montant    Float
  reference  String?
  statut     String  @default("en_cours") // en_cours, accorde, refuse
  notes      String?

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
}

// ==================== QUESTIONNAIRE ====================

model QuestionnaireConfig {
  id        String   @id @default("default")
  updatedAt DateTime @updatedAt
  chaud     Json     @default("[]") // sections [{id, titre, questions:[{key,label}]}]
  froid     Json     @default("[]")
}

// ==================== HISTORIQUE ====================

model HistoriqueAction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  label     String
  detail    String?
  lien      String?

  userId    String?

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  contactId    String?
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  sessionId    String?
  devisId      String?
  factureId    String?
}

// ==================== PARAMETRES ====================

model Parametres {
  id        String   @id @default("default")
  updatedAt DateTime @updatedAt

  nomEntreprise      String @default("RFC - Rescue Formation Conseil")
  slogan             String @default("Sécurité - Incendie - Prévention")
  adresse            String @default("")
  codePostal         String @default("")
  ville              String @default("")
  telephone          String @default("")
  email              String @default("")
  siteWeb            String @default("www.rescueformation83.fr")
  siret              String @default("")
  nda                String @default("")
  tvaIntracom        String @default("")
  conditionsPaiement String @default("Paiement à 30 jours à compter de la date de facturation.")
  mentionsDevis      String @default("Devis valable 30 jours.")
  mentionsFacture    String @default("En cas de retard de paiement, une pénalité de 3 fois le taux d'intérêt légal sera appliquée.")
  iban               String @default("")
  bic                String @default("")
  banque             String @default("")
  moyensPaiement     String @default("virement,cpf,opco")
}

// ==================== MODELES DE MESSAGES ====================

// Templates d'emails / documents parametrables. Chaque type a un template par defaut
// seede, que l'utilisateur peut ensuite modifier a sa guise.
// Les variables de la forme {{nom}} sont remplacees au moment de l'envoi.
model MessageTemplate {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type        String   @unique // convocation, fiche_besoin_client, fiche_besoin_stagiaire, evaluation_chaud, etc.
  nom         String
  description String?
  objet       String   // objet de l'email (avec variables)
  contenu     String   // corps HTML (avec variables)
  variables   String   @default("[]") // JSON array documentant les variables dispo
  actif       Boolean  @default(true)
  modifie     Boolean  @default(false) // true si l'admin a modifie le defaut
}

// ==================== AUTOMATISATIONS ====================

// Regle d'automatisation globale (valeur par defaut appliquee a toutes les sessions)
// Types possibles :
//   fiche_besoin_client, fiche_besoin_stagiaire, positionnement,
//   convocation, convention, rappel_presence, attestation,
//   satisfaction_chaud, satisfaction_froid, facture
model AutomationRule {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type           String  @unique // identifiant unique du type d'action
  label          String  // libelle affiche
  description    String? // description longue
  enabled        Boolean @default(true) // active par defaut pour les nouvelles sessions
  relativeTo     String  @default("dateDebut") // dateDebut, dateFin, inscription, creation_session
  offsetDays     Int     @default(0) // negatif = avant, positif = apres
  offsetHours    Int     @default(0)
  timeOfDay      String? // HH:MM heure d'envoi preferentielle (ex: "09:00")
  canalEmail     Boolean @default(true) // envoi par email
  templateId     String? // ID du template associe (ex: preset_satisfaction_chaud)
  ordre          Int     @default(0)
}

// Override par session : si present, remplace la regle globale pour cette session
model SessionAutomation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type         String
  enabled      Boolean  @default(true)
  relativeTo   String   @default("dateDebut")
  offsetDays   Int      @default(0)
  offsetHours  Int      @default(0)
  timeOfDay    String?
  canalEmail   Boolean  @default(true)
  templateId   String?

  // Tracking execution
  executedAt   DateTime?
  executionLog String? // message ou erreur de la derniere execution

  @@unique([sessionId, type])
  @@index([sessionId])
  @@index([enabled, executedAt])
}

// ==================== QUESTIONNAIRES D'ADAPTATION PEDAGOGIQUE ====================

// Fiche besoin envoyee a l'entreprise cliente pour adapter la formation au contexte metier
model BesoinClient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId    String
  session      Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  tokenAcces  String    @unique
  statut      String    @default("en_attente") // en_attente, envoye, repondu, incomplet
  optionnel   Boolean   @default(false) // true en mode session express
  dateEnvoi   DateTime?
  dateReponse DateTime?

  // Destinataire (pre-rempli depuis contact entreprise si dispo)
  destinataireNom    String?
  destinataireEmail  String?

  // Section 1 - Entreprise
  secteurActivite  String?
  effectifTotal    Int?
  effectifConcerne Int?

  // Section 2 - Stagiaires
  metiersStagiaires      String?
  contexteTravail        String?
  contraintesSpecifiques String?

  // Section 3 - Formation
  objectifPrincipal   String? // renouvellement_carte_pro | premiere_habilitation | recyclage_annuel | autre
  objectifsClient     String?
  casAccidentsRecents Boolean @default(false)
  detailsCasAccidents String?
  contraintesHoraires String?

  // Section 4 - Accessibilite
  aStagiairesHandicap Boolean @default(false)
  detailsHandicap     String?

  @@index([sessionId])
  @@index([entrepriseId])
  @@index([statut])
}

// Fiche besoin individuelle envoyee a chaque stagiaire (Qualiopi + Passeport Prevention)
model BesoinStagiaire {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tokenAcces  String    @unique
  statut      String    @default("en_attente") // en_attente, envoye, repondu, incomplet
  optionnel   Boolean   @default(false)
  dateEnvoi   DateTime?
  dateReponse DateTime?

  // Section 1 - Identification (copie figee au moment de la reponse, distincte du Contact)
  numeroPasseportPrevention String? // decret 2022-1434

  // Section 2 - Prerequis
  dejaSuivi             Boolean   @default(false)
  dateDerniereFormation DateTime?
  niveauFormation       String?  // niveau scolaire general (sans_diplome, cap, bac, etc.)
  niveauPrerequis       String?  // evaluation des prerequis specifiques a la formation (debutant, intermediaire, avance)

  // Section 3 - Accessibilite & contraintes
  estRQTH                 Boolean @default(false)
  detailsRQTH             String?
  contraintesPhysiques    String?
  contraintesLangue       String?
  contraintesAlimentaires String?

  // Section 4 - Consentement
  consentementRGPD Boolean @default(false)
  consentementBPF  Boolean @default(false)

  @@unique([sessionId, contactId])
  @@index([sessionId])
  @@index([contactId])
  @@index([statut])
}
