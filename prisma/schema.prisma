// ==================== TASK MANAGEMENT ====================

// Liste de taches (peut etre liee a une session ou globale)
model TaskList {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  description String?
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId      String?  // utilisateur assigne
  couleur     String   @default("#dc2626")

  items TaskItem[]

  @@index([sessionId])
  @@index([userId])
}

// Tache individuelle dans une liste
model TaskItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listId      String
  list        TaskList @relation(fields: [listId], references: [id], onDelete: Cascade)

  titre       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  priorite    String?   // basse, moyenne, haute, urgente
  ordre       Int       @default(0)
  userId      String?   // utilisateur assigne
  completedAt DateTime?

  @@index([listId])
  @@index([userId])
  @@index([completed])
}

// ==================== CONVERSATIONS GROUPE ====================

// Fil de discussion multi-participants (DirectMessage = 1:1, Conversation = N:N)
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sujet            String?
  dernierMessageAt DateTime?

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  participants ConversationParticipant[]
  messages     ConversationMessage[]

  @@index([sessionId])
  @@index([dernierMessageAt])
}

// Participant a une conversation
model ConversationParticipant {
  id        String   @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

// Message dans une conversation
model ConversationMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId  String   // auteur
  contenu String
  lu      Json     @default("{}") // map { userId: timestamp }

  @@index([conversationId])
  @@index([createdAt])
}

// ==================== PAIEMENTS ====================

