generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== AUTHENTICATION ====================

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String @unique
  password String
  nom      String
  prenom   String
  role     String @default("admin") // admin, formateur, client
  actif    Boolean @default(true)

  formateurId  String?  @unique
  formateur    Formateur? @relation(fields: [formateurId], references: [id])

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id])

  notifications Notification[]
  conversationParticipations ConversationParticipant[]
}

// ==================== CORE MODELS ====================

model Entreprise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom        String
  secteur    String?
  adresse    String?
  ville      String?
  codePostal String?
  siret      String?  @unique
  email      String?
  telephone  String?
  site       String?
  notes      String?

  // Champs complementaires (Qualiopi / BPF)
  effectif       Int?
  typeEntreprise String?  // TPE, PME, ETI, GE

  contacts      Contact[]
  devis         Devis[]
  factures      Facture[]
  users         User[]
  documents     Document[]
  besoins       BesoinFormation[]
  besoinsClient BesoinClient[]
  financements  Financement[]
  historique    HistoriqueAction[]
  tags          EntrepriseTag[]
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom       String
  prenom    String
  email     String  @unique
  telephone String?
  poste     String?
  notes     String?
  type      String  @default("prospect") // prospect, client, stagiaire

  // Donnees stagiaire (Qualiopi / BPF / Passeport Prevention)
  dateNaissance              DateTime?
  numeroSecuriteSociale      String?  // stockage en clair pour l'instant, chiffrement applicatif a prevoir
  numeroPasseportPrevention  String?  // decret 2022-1434
  besoinsAdaptation          String?  // RQTH / contraintes
  niveauFormation            String?  // sans_diplome | cap | bac | bac+2 | autre
  optOutMarketing            Boolean  @default(false) // RGPD : opt-out campagnes marketing

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  inscriptions       Inscription[]
  devis              Devis[]
  attestations       Attestation[]
  evaluations        Evaluation[]
  besoins            BesoinFormation[]
  besoinsStagiaire   BesoinStagiaire[]
  feuillesPresence   FeuillePresence[]
  emargementTokens   EmargementToken[]
  historique         HistoriqueAction[]
  tags               ContactTag[]
  certifications     CertificationStagiaire[]
  badges             BadgeAward[]
  aiDocuments        AiDocumentAnalysis[]
  prospects          Prospect[]
}

model Formateur {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom             String
  prenom          String
  email           String  @unique
  telephone       String?
  specialites     String  @default("[]")
  tarifJournalier Float?
  cv              String?
  photo           String?  // URL photo de profil
  notes           String?
  actif           Boolean @default(true)

  sessions       Session[]
  disponibilites Disponibilite[]
  documents      Document[]
  feedbacks      FeedbackFormateur[]
  user           User?
  notesFrais     NoteFrais[]
  competences    FormateurCompetence[]
  factures       FactureFormateur[]
  evaluations    EvaluationFormateur[]
}

model Formation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre       String
  description String?
  duree       Int      // en heures
  tarif       Float
  niveau      String   @default("tous")
  prerequis   String?
  objectifs   String?
  categorie   String?
  actif       Boolean  @default(true)
  certifiante Boolean  @default(false)
  codeRNCP    String?

  // Nouveaux champs inspirés SoSafe
  modalite           String   @default("presentiel") // presentiel, distanciel, mixte
  statut             String   @default("brouillon") // brouillon, publiee, archivee
  publicCible        String?  // public visé
  contenuProgramme   String?  // contenu détaillé du programme
  methodesPedagogiques String? // méthodes pédagogiques utilisées
  methodesEvaluation String?  // méthodes d'évaluation
  moyensTechniques   String?  // moyens techniques mis à disposition
  accessibilite      String?  // informations sur l'accessibilité PMR
  indicateursResultats String? // indicateurs de résultats
  typesFinancement   String   @default("[]") // JSON array: opco, cpf, entreprise, etc.
  dureeRecyclage     Int?     // durée de recyclage en mois (pour certifications)
  misEnAvant         Boolean  @default(false) // formation featured
  image              String?  // URL image de couverture

  sessions       Session[]
  besoins        BesoinFormation[]
  certifications CertificationStagiaire[]
  badgeTemplates DigitalBadge[] @relation("BadgeFormation")
  parcoursModules ParcoursModule[]

  @@index([statut])
  @@index([categorie])
  @@index([certifiante])
}

model LieuFormation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom              String
  adresse          String?
  codePostal       String?
  ville            String?
  pays             String   @default("France")
  salles           String   @default("[]") // JSON array de noms de salles
  capacite         Int?
  equipements      String?  // description des équipements
  tarifJournee     Float?
  tarifDemiJournee Float?
  contactNom       String?
  contactTelephone String?
  contactEmail     String?
  accessibilitePMR Boolean  @default(false)
  consignesAcces   String?  // comment y accéder
  infoParking      String?
  infoTransport    String?
  notes            String?
  actif            Boolean  @default(true)

  sessions Session[]

  @@index([ville])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dateDebut     DateTime
  dateFin       DateTime
  lieu          String?
  capaciteMax   Int     @default(10)
  statut        String  @default("planifiee") // planifiee, confirmee, en_cours, terminee, annulee
  tokenInscription String? @unique
  notes         String?
  coutFormateur Float?

  // Chemin express (< 48h) : desactive les automatisations temporelles
  modeExpress   Boolean @default(false)

  // Conformite Passeport Prevention (decret 2022-1434) pour formations certifiantes
  declarationPasseportPrevention Boolean   @default(false)
  datePasseportPrevention        DateTime?

  formationId String
  formation   Formation  @relation(fields: [formationId], references: [id], onDelete: Cascade)

  formateurId String?
  formateur   Formateur? @relation(fields: [formateurId], references: [id], onDelete: SetNull)

  lieuFormationId String?
  lieuFormation   LieuFormation? @relation(fields: [lieuFormationId], references: [id], onDelete: SetNull)

  devisId String?
  devis   Devis?  @relation(fields: [devisId], references: [id], onDelete: SetNull)

  inscriptions       Inscription[]
  feuillesPresence   FeuillePresence[]
  attestations       Attestation[]
  evaluations        Evaluation[]
  feedbacks          FeedbackFormateur[]
  documents          Document[]
  besoinsClient      BesoinClient[]
  besoinsStagiaire   BesoinStagiaire[]
  automations        SessionAutomation[]
  emargementTokens   EmargementToken[]
  forumTopics        ForumTopic[]
  classeVirtuelle    ClasseVirtuelle?
  sessionParcours    SessionParcours[]
  taskLists          TaskList[]
  conversations      Conversation[]
  facturesFormateur  FactureFormateur[]
  evaluationsFormateur EvaluationFormateur[]
}

model Inscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statut          String   @default("en_attente") // en_attente, confirmee, annulee, presente, absente
  dateInscription DateTime @default(now())
  notes           String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([contactId, sessionId])
}

// ==================== COMMERCIAL ====================

model BesoinFormation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre       String
  description String?
  origine     String  @default("client") // client, stagiaire, centre
  statut      String  @default("nouveau") // nouveau, qualifie, devis_envoye, accepte, refuse, archive
  priorite    String  @default("normale") // basse, normale, haute, urgente
  nbStagiaires Int?
  datesSouhaitees String?
  budget      Float?
  notes       String?

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  contactId    String?
  contact      Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  formationId  String?
  formation    Formation?  @relation(fields: [formationId], references: [id], onDelete: SetNull)

  devisId      String?
  devis        Devis?      @relation(fields: [devisId], references: [id], onDelete: SetNull)

  @@index([statut])
  @@index([entrepriseId])
  @@index([contactId])
  @@index([createdAt])
}

model Devis {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numero       String   @unique
  objet        String
  montantHT    Float
  tauxTVA      Float    @default(20)
  montantTTC   Float
  dateEmission DateTime @default(now())
  dateValidite DateTime
  dateSigne    DateTime?
  signatureUrl String?
  notes        String?
  statut       String   @default("brouillon") // brouillon, envoye, signe, refuse, expire

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  lignes   LigneDevis[]
  factures Facture[]
  besoins  BesoinFormation[]
  sessions Session[]
}

model LigneDevis {
  id String @id @default(cuid())

  designation  String
  quantite     Int   @default(1)
  prixUnitaire Float
  montant      Float

  devisId String
  devis   Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
}

model Facture {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numero       String   @unique
  montantHT    Float
  tauxTVA      Float    @default(20)
  montantTTC   Float
  dateEmission DateTime @default(now())
  dateEcheance DateTime
  datePaiement   DateTime?
  paiements      Json?     // [{mode: string, montant: number}]
  notes          String?
  statut         String   @default("en_attente") // en_attente, envoyee, payee, en_retard, annulee

  devisId String?
  devis   Devis?  @relation(fields: [devisId], references: [id], onDelete: SetNull)

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)

  paiementsRecus       Paiement[]
  echeances            EcheancierPaiement[]
  transactionsBancaires TransactionBancaire[]
}

// ==================== FORMATEUR ====================

model Disponibilite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  dateDebut DateTime
  dateFin   DateTime
  type      String   @default("disponible") // disponible, indisponible
  notes     String?

  formateurId String
  formateur   Formateur @relation(fields: [formateurId], references: [id], onDelete: Cascade)

  @@index([formateurId, dateDebut])
}

model FeedbackFormateur {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  noteGlobale       Int     // 1-5
  commentaire       String?
  conditionsMat     String? // conditions matérielles
  dynamiqueGroupe   String?
  suggestions       String?

  formateurId String
  formateur   Formateur @relation(fields: [formateurId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([formateurId, sessionId])
}

// ==================== DOCUMENTS ====================

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nom        String
  type       String  // convention, feuille_presence, convocation, attestation, contrat, autre
  chemin     String  // file path or URL
  taille     Int?    // file size in bytes

  sessionId    String?
  session      Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  formateurId  String?
  formateur    Formateur?  @relation(fields: [formateurId], references: [id], onDelete: SetNull)

  entrepriseId String?
  entreprise   Entreprise? @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
}

// ==================== EVALUATIONS & ATTESTATIONS ====================

model Evaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type         String  // satisfaction_chaud, satisfaction_froid, acquis
  cible        String  // stagiaire, client, formateur
  noteGlobale  Int?    // 1-5
  reponses     String  @default("{}") // JSON des réponses
  commentaire  String?
  estComplete  Boolean @default(false)
  tokenAcces   String? @unique // pour accès par lien unique

  // Snapshot des questions du template au moment de l'envoi (fige le contenu).
  // Si null, fallback sur le template associe (ou QuestionnaireConfig pour l'ancien systeme).
  questionsSnapshot String?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model EvaluationTemplate {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nom         String
  description String?
  type        String   @default("custom") // satisfaction_chaud, satisfaction_froid, acquis, custom
  questions   String   @default("[]") // JSON array of question objects
  preset      Boolean  @default(false) // true = preset officiel non modifiable
  icon        String?  // icone lucide ou emoji
  ordre       Int      @default(0) // ordre d'affichage dans le catalogue
}

model Attestation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type         String  @default("fin_formation") // fin_formation, presence, competences
  statut       String  @default("generee") // generee, validee, envoyee
  chemin       String? // file path
  dateValidation DateTime?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sessionId, contactId, type])
}

model FeuillePresence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  date      DateTime
  matin     Boolean @default(false)
  apresMidi Boolean @default(false)
  signature String? // legacy V1 — remplace par champs V2 ci-dessous

  // V2 Emargement numerique — statuts detailles
  statutMatin     String?  // present, absent, en_retard, excuse, depart_anticipe
  statutApresMidi String?
  retardMinutes   Int?     // minutes de retard (si en_retard)
  departMinutes   Int?     // minutes avant la fin (si depart_anticipe)

  // V2 Signatures numeriques (base64 PNG data URL)
  signatureMatin     String?
  signatureApresMidi String?

  // V2 Metadonnees de signature (preuve Qualiopi)
  signatureMatinIp   String?
  signatureMatinAt   DateTime?
  signatureAmIp      String?
  signatureAmAt      DateTime?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sessionId, contactId, date])
}

// ==================== EMARGEMENT NUMERIQUE V2 ====================

// Token pour acces public a l'emargement (QR code ou OTP individuel).
// Si contactId est null → token QR general (tous les stagiaires de la session peuvent signer).
// Si contactId est set → token OTP individuel (un seul stagiaire, envoye par email).
model EmargementToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date      DateTime  // jour concerne
  creneau   String    // matin | apres_midi

  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime? // rempli quand le token OTP est utilise

  contactId String?   // null = QR general, set = OTP individuel
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([sessionId])
}

// ==================== CRM MARKETING (V2 Lot 2) ====================

// Tags libres sur les contacts / entreprises
model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  nom       String   @unique
  couleur   String   @default("#6b7280") // hex color pour affichage badge

  contacts    ContactTag[]
  entreprises EntrepriseTag[]
}

model ContactTag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
}

model EntrepriseTag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  entrepriseId String
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([entrepriseId, tagId])
}

// Campagnes marketing (email / SMS)
model MarketingCampaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom          String
  description  String?
  type         String  @default("email") // email, sms
  statut       String  @default("brouillon") // brouillon, planifiee, envoyee, annulee

  // Ciblage : JSON array de criteres ou liste de tagIds
  segmentConfig String @default("{}") // JSON { tags: [], formations: [], type: "stagiaire", ... }

  // Contenu
  objet    String? // sujet email
  contenu  String? // HTML email ou texte SMS
  templateId String? // reference un MessageTemplate

  // Planification
  dateEnvoi    DateTime?
  dateEnvoyee  DateTime?

  // Stats
  nbDestinataires Int @default(0)
  nbEnvoyes       Int @default(0)
  nbOuverts       Int @default(0)
  nbClics         Int @default(0)
  nbDesinscriptions Int @default(0)

  recipients CampaignRecipient[]

  @@index([statut])
  @@index([dateEnvoi])
}

model CampaignRecipient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  contactId String

  statut    String  @default("pending") // pending, sent, opened, clicked, bounced, unsubscribed
  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?

  @@unique([campaignId, contactId])
  @@index([campaignId])
}

// Opt-out marketing RGPD
model MarketingOptOut {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email     String  @unique
  reason    String? // opt-out volontaire, bounce, plainte

  @@index([email])
}

// ==================== BADGES NUMERIQUES (V2 Lot 3) ====================

// Definition d'un badge (template) — cree par l'admin
model DigitalBadge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  description String?
  icone       String?  // URL image / emoji
  niveau      String   @default("bronze") // bronze, argent, or
  couleur     String   @default("#dc2626")

  // Critere d'attribution automatique
  formationId String?  // si set, attribue auto a la completion de cette formation
  formation   Formation? @relation("BadgeFormation", fields: [formationId], references: [id], onDelete: SetNull)

  actif       Boolean @default(true)

  awards BadgeAward[]
}

// Attribution d'un badge a un stagiaire
model BadgeAward {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  badgeId   String
  badge     DigitalBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  sessionId String? // session d'obtention
  revoque   Boolean @default(false)
  revoqueAt DateTime?
  revoqueRaison String?

  // Token de verification publique
  verificationToken String @unique @default(cuid())

  @@unique([badgeId, contactId])
  @@index([contactId])
  @@index([verificationToken])
}

// ==================== ANALYSE IA DOCUMENTS (V2 Lot 3) ====================

// Resultat d'analyse IA d'un document uploade (habilitation, carte pro, diplome)
model AiDocumentAnalysis {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  documentUrl String  // URL du fichier dans Supabase Storage
  documentNom String  // nom original du fichier

  // Resultats IA
  typeDetecte      String?  // habilitation_electrique, carte_btp, carte_pro, diplome, autre
  nomDetecte       String?  // nom du titulaire extrait
  dateEmission     DateTime?
  dateExpiration   DateTime?
  scoreConfiance   Int      @default(0) // 0-100
  donneesExtraites String   @default("{}") // JSON avec tous les champs extraits

  // Workflow validation
  statut           String   @default("en_attente") // en_attente, valide_auto, valide_manuel, rejete, a_verifier
  commentaireAdmin String?
  valideParId      String?  // userId admin qui a valide

  @@index([contactId])
  @@index([statut])
}

// ==================== RECYCLAGES (V2 Lot 2) ====================

// Suivi des certifications stagiaires (date obtention + date expiration calculee)
model CertificationStagiaire {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  sessionId   String?  // session d'obtention (si connue)

  dateObtention  DateTime
  dateExpiration DateTime? // calculee : dateObtention + formation.dureeRecyclage mois
  statut         String    @default("valide") // valide, expire, en_cours_recyclage

  alerteJ60Envoyee Boolean @default(false)
  alerteJ30Envoyee Boolean @default(false)

  @@index([contactId])
  @@index([formationId])
  @@index([dateExpiration])
}

// ==================== FORUM & MESSAGERIE (V2 Lot 4) ====================

model ForumTopic {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre     String
  contenu   String
  epingle   Boolean @default(false)
  verrouille Boolean @default(false)

  // Scope : si sessionId set → forum de session, sinon forum general
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  categorie String? // incendie, premiers_secours, general, ...

  auteurId  String // contactId ou formateurId
  auteurNom String // cache pour affichage

  replies   ForumReply[]

  @@index([sessionId])
  @@index([createdAt])
}

model ForumReply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contenu   String
  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  auteurId  String
  auteurNom String

  @@index([topicId])
}

model DirectMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contenu    String
  expediteur String // userId ou contactId
  expediteurNom String
  destinataire String
