// ============================================================
// ============== EXTENSIONS V2 — INSPIRE DE SO SAFE ===========
// ============================================================
// Modeles ajoutes pour atteindre la parite fonctionnelle avec
// SO SAFE (hors e-learning et quiz live). Aucun modele existant
// n'est touche dans ce fichier.

// ==================== PARCOURS DE FORMATION ====================

// Parcours = enchainement de plusieurs formations (ex : SSIAP1 -> SSIAP2 -> recyclage)
model Parcours {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  description String?
  duree       Int      // total en heures
  tarif       Float?
  actif       Boolean  @default(true)
  categorie   String?
  niveau      String?

  modules  ParcoursModule[]
  sessions SessionParcours[]

  @@index([actif])
  @@index([categorie])
}

// Formations qui composent un parcours (avec ordre)
model ParcoursModule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  parcoursId  String
  parcours    Parcours  @relation(fields: [parcoursId], references: [id], onDelete: Cascade)

  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  ordre       Int     @default(0)
  obligatoire Boolean @default(true)

  @@unique([parcoursId, formationId])
  @@index([parcoursId])
  @@index([formationId])
}

// Pivot session <-> parcours : une session peut etre rattachee a un parcours
model SessionParcours {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  parcoursId String
  parcours   Parcours @relation(fields: [parcoursId], references: [id], onDelete: Cascade)

  @@unique([sessionId, parcoursId])
  @@index([sessionId])
  @@index([parcoursId])
}

// ==================== PROSPECTS CRM ====================

// Pipeline commercial (different de Contact.type=prospect : avec scoring/source/conversion)
model Prospect {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom        String
  prenom     String
  email      String?
  telephone  String?
  entreprise String?  // nom libre (pas de FK : prospect pas encore qualifie)
  source     String?  // web, salon, recommandation, autre
  statut     String   @default("nouveau") // nouveau, qualifie, proposition, gagne, perdu
  score      Int?     // 0-100
  notes      String?
  attribueA  String?  // userId
  dateProchaineAction DateTime?
  dateConversion      DateTime?

  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  activities ProspectActivity[]

  @@index([statut])
  @@index([attribueA])
  @@index([contactId])
  @@index([createdAt])
