// ==================== MODELES DE DOCUMENTS (PDF) ====================

// Templates des documents PDF generes (convocation, convention, attestation, etc.).
// Permettent de modifier le texte du document sans toucher au code.
// Integre automatiquement le logo et la couleur de l'entreprise via Parametres.
model DocumentTemplate {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type         String  @unique // convocation, convention, attestation, feuille_presence, devis, facture
  nom          String
  description  String?
  titre        String  // Titre principal en haut du document
  introduction String? // Paragraphe d'introduction (variables OK)
  corps        String  // Corps principal (variables OK, saut de ligne \n)
  mentions     String? // Mentions legales / pied de page
  variables    String  @default("[]")
  actif        Boolean @default(true)
  modifie      Boolean @default(false)

  generatedDocuments GeneratedDocument[]
}

// ==================== MODELES DE MESSAGES ====================

// Templates d'emails / documents parametrables. Chaque type a un template par defaut
// seede, que l'utilisateur peut ensuite modifier a sa guise.
// Les variables de la forme {{nom}} sont remplacees au moment de l'envoi.
model MessageTemplate {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type        String   @unique // convocation, fiche_besoin_client, fiche_besoin_stagiaire, evaluation_chaud, etc.
  nom         String
  description String?
  objet       String   // objet de l'email (avec variables)
  contenu     String   // corps HTML (avec variables)
  variables   String   @default("[]") // JSON array documentant les variables dispo
  actif       Boolean  @default(true)
  modifie     Boolean  @default(false) // true si l'admin a modifie le defaut

  logEmails   LogEmail[]
}

// ==================== AUTOMATISATIONS ====================

// Regle d'automatisation globale (valeur par defaut appliquee a toutes les sessions)
// Types possibles :
//   fiche_besoin_client, fiche_besoin_stagiaire, positionnement,
//   convocation, convention, rappel_presence, attestation,
//   satisfaction_chaud, satisfaction_froid, facture
model AutomationRule {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type           String  @unique // identifiant unique du type d'action
  label          String  // libelle affiche
  description    String? // description longue
  enabled        Boolean @default(true) // active par defaut pour les nouvelles sessions
  relativeTo     String  @default("dateDebut") // dateDebut, dateFin, inscription, creation_session
  offsetDays     Int     @default(0) // negatif = avant, positif = apres
  offsetHours    Int     @default(0)
  timeOfDay      String? // HH:MM heure d'envoi preferentielle (ex: "09:00")
  canalEmail     Boolean @default(true) // envoi par email
  templateId     String? // ID du template associe (ex: preset_satisfaction_chaud)
  ordre          Int     @default(0)
}

// Override par session : si present, remplace la regle globale pour cette session
model SessionAutomation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type         String
  enabled      Boolean  @default(true)
  relativeTo   String   @default("dateDebut")
  offsetDays   Int      @default(0)
  offsetHours  Int      @default(0)
  timeOfDay    String?
  canalEmail   Boolean  @default(true)
  templateId   String?

  // Tracking execution
  executedAt   DateTime?
  executionLog String? // message ou erreur de la derniere execution

  @@unique([sessionId, type])
  @@index([sessionId])
  @@index([enabled, executedAt])
}

// ==================== AUTOMATISATIONS V2 (Builder graphique) ====================

// Regle d'automatisation V2 — creee via le builder admin.
// Pattern : declencheur → conditions → delai → action.
// Coexiste avec les regles V1 (AutomationRule) sans interference.
model AutomationRuleV2 {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom         String
  description String?
  enabled     Boolean @default(true)
  ordre       Int     @default(0)

  // Declencheur
  trigger     String // inscription, session_start, session_end, j_minus_1, j_minus_7, j_minus_30, status_change, creation_session

  // Conditions (JSON array) : [{ field, operator, value }]
  // field : formation.categorie, contact.type, inscription.statut, formation.id, financement.type
  // operator : equals, in, not_equals
  conditions  String @default("[]")

  // Delai avant execution
  delayType   String @default("immediate") // immediate, minutes, hours, days
  delayValue  Int    @default(0)

  // Action a executer
  actionType   String // send_email, send_sms, generate_document, create_task, change_status
  actionConfig String @default("{}") // JSON : { templateId?, documentType?, targetStatus?, taskTitle?, smsContent? }

  // Cle de deduplication : empeche les doublons
  deduplicationKey String @default("session_contact") // session_contact, session, contact

  executions AutomationExecutionV2[]

  @@index([enabled, trigger])
}

// Log d'execution des regles V2 — tracabilite complete
model AutomationExecutionV2 {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ruleId    String
  rule      AutomationRuleV2 @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  sessionId String
  contactId String?

  status       String  // success, error, skipped, dry_run
  payload      String? // JSON contexte complet
  errorMessage String?

  deduplicationHash String?

  @@index([ruleId])
  @@index([sessionId])
  @@index([deduplicationHash])
  @@index([createdAt])
}

